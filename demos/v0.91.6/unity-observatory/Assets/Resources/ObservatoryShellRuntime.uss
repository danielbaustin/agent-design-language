.observatory-screen {
  flex-grow: 1;
  padding: 18px;
  background-color: rgb(5, 8, 18);
  color: rgb(232, 238, 255);
}

.observatory-shell {
  flex-grow: 1;
  flex-direction: column;
  background-color: rgb(11, 15, 28);
}

.header {
  padding-bottom: 16px;
}

#title {
  color: rgb(245, 248, 255);
  font-size: 24px;
}

#subtitle {
  color: rgb(171, 186, 224);
  font-size: 13px;
}

.body {
  flex-grow: 1;
  flex-direction: row;
}

.navigation {
  width: 180px;
  padding-right: 12px;
  color: rgb(171, 186, 224);
}

.content {
  flex-grow: 1;
  flex-direction: column;
}

.card {
  padding: 14px;
  margin-bottom: 14px;
  background-color: rgb(18, 24, 42);
  color: rgb(232, 238, 255);
}

.footer {
  padding-top: 16px;
  color: rgb(171, 186, 224);
}
