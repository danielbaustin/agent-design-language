{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adl.dev/schemas/experiment_record.v1.schema.json",
  "title": "ExperimentRecord v1",
  "description": "Canonical design-stage schema for deterministic experiment records.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "experiment_id",
    "comparison_key",
    "runs",
    "hypothesis",
    "mutation",
    "evaluation_plan",
    "evidence",
    "outcome",
    "decision",
    "replay",
    "obsmem_index"
  ],
  "properties": {
    "schema_name": {
      "type": "string",
      "const": "experiment_record"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "experiment_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "comparison_key": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "baseline_label", "variant_label"],
      "properties": {
        "subject": { "type": "string", "minLength": 1 },
        "baseline_label": { "type": "string", "minLength": 1 },
        "variant_label": { "type": "string", "minLength": 1 }
      }
    },
    "runs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline_run_id", "variant_run_id"],
      "properties": {
        "baseline_run_id": { "type": "string", "minLength": 1 },
        "variant_run_id": { "type": "string", "minLength": 1 }
      }
    },
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "expected_effect"],
      "properties": {
        "statement": { "type": "string", "minLength": 1 },
        "expected_effect": { "type": "string", "minLength": 1 },
        "risk_class": { "type": "string", "enum": ["low", "medium", "high"] },
        "success_criteria": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "mutation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mutation_id", "mutation_version", "mutation_ref", "scope"],
      "properties": {
        "mutation_id": { "type": "string", "minLength": 1 },
        "mutation_version": { "type": "integer", "minimum": 1 },
        "mutation_ref": { "$ref": "#/$defs/repo_relative_ref" },
        "scope": {
          "type": "array",
          "items": { "$ref": "#/$defs/repo_relative_ref" },
          "minItems": 1,
          "uniqueItems": true
        },
        "change_summary": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "evaluation_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evaluation_plan_id", "evaluation_plan_version", "evaluation_plan_ref", "check_ids"],
      "properties": {
        "evaluation_plan_id": { "type": "string", "minLength": 1 },
        "evaluation_plan_version": { "type": "integer", "minimum": 1 },
        "evaluation_plan_ref": { "$ref": "#/$defs/repo_relative_ref" },
        "check_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_evidence_view_id",
        "canonical_evidence_view_version",
        "canonical_evidence_ref",
        "evidence_items"
      ],
      "properties": {
        "canonical_evidence_view_id": { "type": "string", "minLength": 1 },
        "canonical_evidence_view_version": { "type": "integer", "minimum": 1 },
        "canonical_evidence_ref": { "$ref": "#/$defs/repo_relative_ref" },
        "evidence_items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["evidence_id", "kind", "value", "source_ref"],
            "properties": {
              "evidence_id": { "type": "string", "minLength": 1 },
              "kind": {
                "type": "string",
                "enum": ["trace", "verification", "artifact_hash", "failure_code", "metric"]
              },
              "value": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "number" },
                  { "type": "integer" },
                  { "type": "boolean" }
                ]
              },
              "source_ref": { "$ref": "#/$defs/repo_relative_ref" }
            }
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_metric", "direction", "baseline_value", "variant_value", "delta"],
      "properties": {
        "primary_metric": { "type": "string", "minLength": 1 },
        "direction": {
          "type": "string",
          "enum": ["increase_is_better", "decrease_is_better", "target_match"]
        },
        "baseline_value": { "type": "number" },
        "variant_value": { "type": "number" },
        "delta": { "type": "number" },
        "secondary_metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["metric", "direction", "baseline_value", "variant_value", "delta"],
            "properties": {
              "metric": { "type": "string", "minLength": 1 },
              "direction": {
                "type": "string",
                "enum": ["increase_is_better", "decrease_is_better", "target_match"]
              },
              "baseline_value": { "type": "number" },
              "variant_value": { "type": "number" },
              "delta": { "type": "number" }
            }
          },
          "uniqueItems": true
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result", "rationale"],
      "properties": {
        "result": {
          "type": "string",
          "enum": ["adopt", "reject", "requires_human_review"]
        },
        "rationale": { "type": "string", "minLength": 1 },
        "blocking_reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "replay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["replay_profile", "artifact_manifest"],
      "properties": {
        "replay_profile": { "type": "string", "minLength": 1 },
        "artifact_manifest": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": { "$ref": "#/$defs/repo_relative_ref" },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "replay_notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "obsmem_index": {
      "type": "object",
      "additionalProperties": false,
      "required": ["memory_kind", "index_key", "tags", "facets"],
      "properties": {
        "memory_kind": {
          "type": "string",
          "const": "experiment_record"
        },
        "index_key": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "facets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["decision_result", "primary_metric", "subject"],
          "properties": {
            "decision_result": {
              "type": "string",
              "enum": ["adopt", "reject", "requires_human_review"]
            },
            "primary_metric": { "type": "string", "minLength": 1 },
            "subject": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "policy_approval_ref": {
      "$ref": "#/$defs/repo_relative_ref"
    },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "$defs": {
    "repo_relative_ref": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        { "not": { "pattern": "^/" } },
        { "not": { "pattern": "^[A-Za-z]:[/\\\\]" } },
        { "not": { "pattern": "\\.\\." } }
      ]
    }
  }
}
