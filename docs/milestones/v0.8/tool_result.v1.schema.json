{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adl://schemas/tool_result.v1.schema.json",
  "title": "ToolResult v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_name",
    "invocation_id",
    "status",
    "artifact_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "tool_result.v1"
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "invocation_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failure",
        "partial"
      ]
    },
    "payload": {},
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path",
          "sha256"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "pattern": "^(\\.adl|docs|swarm|out|tmp)/[A-Za-z0-9_./:-]+$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "failure"
          }
        }
      },
      "then": {
        "required": [
          "error"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "success"
          }
        }
      },
      "then": {
        "not": {
          "required": [
            "error"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "partial"
          }
        }
      },
      "then": {
        "required": [
          "payload"
        ]
      }
    }
  ]
}
