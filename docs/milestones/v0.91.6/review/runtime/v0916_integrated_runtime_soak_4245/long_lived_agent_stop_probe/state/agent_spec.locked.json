{
  "schema": "adl.long_lived_agent_spec.v1",
  "agent_instance_id": "v0916-runtime-stop-probe",
  "display_name": "V0916 Runtime Soak",
  "state_root": "state",
  "workflow": {
    "kind": "demo_adapter",
    "name": "v0916_runtime_soak",
    "path": null,
    "run_args": {
      "model": "gemma4:latest",
      "provider_id": "local_ollama"
    }
  },
  "heartbeat": {
    "interval_secs": 1,
    "max_cycles": 6,
    "stale_lease_after_secs": 60
  },
  "safety": {
    "allow_broker": false,
    "allow_filesystem_writes_outside_state_root": false,
    "allow_network": false,
    "allow_real_world_side_effects": false,
    "financial_advice": false,
    "max_consecutive_failures": 2,
    "max_cycle_runtime_secs": 120,
    "require_public_artifact_sanitization": true
  },
  "memory": {
    "namespace": "runtime/soak/v0916",
    "write_policy": "append_only"
  }
}
